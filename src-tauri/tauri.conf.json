{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "DevPortfolio",
  "version": "1.0.0",
  "identifier": "com.devportfolio.app",
  "build": {
    "frontendDist": "../.next",
    "devUrl": "http://localhost:3005",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "DevPortfolio - 现代程序员作品集",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
